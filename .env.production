# Production uses the Vercel rewrite in vercel.json, so API requests stay same-origin.
VITE_API_BASE_URL=

# Fill this with the GitHub OAuth app client id before deploying GitHub login.
VITE_GITHUB_CLIENT_ID=
# Leave empty to use the current frontend domain, e.g. https://tiku.020417.xyz/github/callback.
VITE_GITHUB_REDIRECT_URI=
VITE_GITHUB_SCOPE=read:user user:email
